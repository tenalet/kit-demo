# Your partner API key (from Tenalet admin dashboard)
# New partners start with a test key (tnlt_pk_test_...).
# Use POST /admin/partners/:id/rotate-key?mode=live to provision a live key.
TENALET_API_KEY=tnlt_pk_test_your_key_here

# Webhook secret (must match what's configured for your partner account)
TENALET_WEBHOOK_SECRET=

# Port for the demo server
PORT=3500
